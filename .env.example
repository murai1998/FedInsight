# FedInsight environment configuration
# Copy this file to .env and adjust as needed.

# ---------------------------------------------------------------------------
# Vector store backend selector: "pgvector" (default) or "chroma"
#   pgvector -> PostgreSQL; start it locally with `docker compose up -d`
#   chroma   -> on-disk, server-less (used by the Hugging Face Space)
# ---------------------------------------------------------------------------
VECTOR_BACKEND=pgvector

# ChromaDB (used when VECTOR_BACKEND=chroma) - on-disk, no server needed
CHROMA_PERSIST_DIR=data/chroma

# ---------------------------------------------------------------------------
# pgvector / PostgreSQL (used when VECTOR_BACKEND=pgvector)
# ---------------------------------------------------------------------------
# Option A: single connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fedinsight

# Option B: individual parts (used if DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGDATABASE=fedinsight
PGUSER=postgres
PGPASSWORD=postgres

# ---------------------------------------------------------------------------
# LLM provider for RAG answers: "auto" (default), "openai", "ollama", or "none"
#   auto  -> OpenAI if OPENAI_API_KEY is set, else Ollama if reachable, else none
#   none  -> no generation; returns retrieved excerpts only (works fully offline)
# ---------------------------------------------------------------------------
LLM_PROVIDER=auto

# OpenAI (used when provider is "openai", or "auto" with a key present)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (local, used when provider is "ollama", or "auto" with no OpenAI key)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
